// Program to check if two strings are anagrams

let str1 = "listen";
let str2 = "silent";

// Convert strings to arrays of characters
let arr1 = str1.split("");
let arr2 = str2.split("");

// Sort both arrays
arr1.sort();
arr2.sort();

// Compare sorted arrays
if (arr1.join("") === arr2.join("")) 
{
  console.log("Anagrams");
}
else
{
  console.log("Not anagrams");
}
