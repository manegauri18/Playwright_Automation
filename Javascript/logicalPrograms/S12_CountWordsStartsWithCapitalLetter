// Program to count words starting with a capital letter

let inputString = "This is a Sample String With Capitalized Words";
let words = inputString.split(" ");
let count = 0;

for (let i = 0; i < words.length; i++) 
    
{
  let word = words[i];
  
 
  if  (word[0] >= 'A' && word[0] <= 'Z') 
{
    console.log("Capitalized word is: " + word); // Print words if required
    count++;
  }
}

console.log("Number of capitalized words: " + count);
