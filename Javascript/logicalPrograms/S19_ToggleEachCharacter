let input = "HeLLo WoRLd 123!";
let toggled = "";

for (let ch of input) 
{

    if (ch >= 'A' && ch <= 'Z') 
    {
        toggled += ch.toLowerCase();
    }
    else if (ch >= 'a' && ch <= 'z') 
    {
        toggled += ch.toUpperCase();
    }
    else 
    {
        toggled += ch;
    }
}

console.log("Original:", input);
console.log("Toggled:", toggled);