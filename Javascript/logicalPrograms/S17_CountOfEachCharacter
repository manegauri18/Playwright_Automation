let input = "aabbbccccddddde";

let charMap = new Map();

for (let c of input) 
  {

    if (charMap.has(c)) 
    {
        charMap.set(c, charMap.get(c) + 1);
    } 
    
    else 
    {
        charMap.set(c, 1);
    }
}

// Print results
for (let [key, value] of charMap) 
{
    console.log(key + ": " + value);
}