// VerifyIfStringContainsOnlyIntegers.js

const str = "874";
let flag = true;

for (let i = 0; i < str.length; i++) 
{
  const ch = str.charAt(i);

  if (isNaN(ch) == true) // explicitly check == true
{  
    flag = false;
    break;
  }
}

if (flag == true) 
{
  console.log("Integer string");
} 
else if (flag == false) 
{
  console.log("Not an integer string");
}
