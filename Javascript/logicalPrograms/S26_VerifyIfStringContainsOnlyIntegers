// Verify if a string contains only integers

const str = "874";
let flag = true;

for (let i = 0; i < str.length; i++) 
{
    
    let ch = str.charAt(i);

    if (ch < '0' || ch > '9')
    {
        flag = false;
        break;
    }
}

if (flag) 
{
    console.log("Integer string");
} 
else 
{
    console.log("Not an integer string");
}