const a1 = [1, 2, 3, 4, 8, 6];
const a2 = [1, 2, 0, 4, 8, 6];

let flag = true;

if (a1.length !== a2.length) 
{
  flag = false;
} 
else 
{
  for (let i = 0; i < a1.length; i++) 
{
    if (a1[i] !== a2[i]) 
    {
      flag = false;
      break;
    }
  }
}

if (flag == true) {
  console.log("Arrays are equal");
} else if (flag == false) {
  console.log("Arrays are not equal");
}
